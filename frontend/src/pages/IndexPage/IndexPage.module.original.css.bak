.root {
  --page-bg: #faf8f5;
  --surface: #ffffff;
  --ink: #1a1a1f;
  --ink-soft: #4a4a52;
  --ink-muted: #8a8a93;
  --brand: #8b3a52;
  --brand-soft: #fdf2f4;
  --brand-icon: #f5dadf;
  --hairline: rgba(20, 20, 26, 0.06);
  --shadow-card: 0 1px 2px rgba(20, 20, 26, 0.04), 0 4px 16px -8px rgba(20, 20, 26, 0.08);
  --shadow-card-hover: 0 1px 2px rgba(20, 20, 26, 0.04), 0 12px 28px -10px rgba(20, 20, 26, 0.14);

  min-height: 100vh;
  min-height: 100dvh;
  background: var(--page-bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  padding-top: calc(
    var(--tg-viewport-safe-area-inset-top, 0px) +
    var(--tg-viewport-content-safe-area-inset-top, 0px) +
    24px
  );
  padding-right: calc(var(--tg-viewport-content-safe-area-inset-right, 0px) + 16px);
  padding-bottom: calc(var(--tg-viewport-safe-area-inset-bottom, 0px) + 40px);
  padding-left: calc(var(--tg-viewport-content-safe-area-inset-left, 0px) + 16px);
}

/* ---------- hero ---------- */
.hero {
  text-align: left;
  padding: 4px 4px 28px;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16px;
}

.logo {
  width: 92px;
  height: 92px;
  border-radius: 22px;
  object-fit: cover;
  display: block;
  flex-shrink: 0;
  box-shadow: 0 6px 24px -12px rgba(139, 58, 82, 0.5);
}

.heroText {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.title {
  margin: 0;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.015em;
  color: var(--ink);
  line-height: 1.15;
}

.tagline {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
  color: var(--ink-muted);
}

/* ---------- sections ---------- */
.sections {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sectionLabel {
  margin: 0 4px 2px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--ink-muted);
  text-transform: uppercase;
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.sectionFooter {
  margin: 10px 4px 0;
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-muted);
}

/* ---------- card ---------- */
.card {
  appearance: none;
  width: 100%;
  text-align: left;
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr) auto;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  background: var(--surface);
  color: var(--ink);
  border: 1px solid var(--hairline);
  border-radius: 16px;
  cursor: pointer;
  font: inherit;
  box-shadow: var(--shadow-card);
  transition: transform 0.15s cubic-bezier(0.2, 0.8, 0.2, 1),
              box-shadow 0.2s ease;
}

.card:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-card-hover);
}

.card:active {
  transform: translateY(0) scale(0.99);
  box-shadow: var(--shadow-card);
}

.card:focus-visible {
  outline: 2px solid var(--brand);
  outline-offset: 2px;
}

.cardIcon {
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.cardIcon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.cardBody {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.cardTitle {
  font-size: 15.5px;
  font-weight: 600;
  line-height: 1.25;
  color: var(--ink);
  letter-spacing: -0.005em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cardSubtitle {
  font-size: 13px;
  font-weight: 400;
  color: var(--ink-muted);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cardArrow {
  width: 22px;
  height: 22px;
  display: grid;
  place-items: center;
  color: var(--ink-muted);
  opacity: 0.55;
  flex-shrink: 0;
}

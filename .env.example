# Copy to .env and fill in.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True

# Database (defaults match docker-compose.yml)
DB_HOST=postgres
DB_PORT=5432
DB_USER=baxtiyor
DB_PASSWORD=dev_password
DB_NAME=baxtiyor_dev

# Telegram
# From @BotFather
BOT_TOKEN=
# Telegram group/chat ID. Members of this group are treated as admins.
# Get the ID by adding the bot to the group and forwarding a message to @userinfobot,
# or via getUpdates. Looks like -1001234567890.
TELEGRAM_ADMIN_GROUP_ID=
# Direct link to the Mini App (from @BotFather → your app), e.g.
# https://t.me/BaxtiyorOilaBot/app. Used to deep-link admins from the group
# notification straight into a user's chat thread (?startapp=chat_<id>).
MINIAPP_URL=

# Cache TTLs
ADMIN_CACHE_TTL_SECONDS=300
INIT_DATA_MAX_AGE_SECONDS=86400
